# Production build env for @workspace/animator-app
# Copy values into Vercel → Environment Variables → Production
# Prefer vercel.json rewrites for APIs; only set these when overriding.

# Mine-Loader Realms iframe / deep links
VITE_MINELOADER_URL=https://mine-loader.vercel.app

# Optional: serve models/anims from R2 instead of same-origin public/
# VITE_ASSET_BASE_URL=https://assets.grudge-studio.com

# Optional: dedicated WebSocket game server (else same-origin /api/danger)
# VITE_GAME_SERVER_URL=wss://gameopen-production.up.railway.app

# Optional: absolute game API (else same-origin /api → Railway via vercel.json)
# VITE_GAME_API_URL=https://grudge-api-production-0d46.up.railway.app

# Optional Clerk (Grudge ID Puter is primary)
# VITE_CLERK_PUBLISHABLE_KEY=
# VITE_CLERK_PROXY_URL=

# Vite base path for this project (always / on threejs-rapier-react-three-controll)
# BASE_PATH=/
